{
  "expo": {
    "name": "RouteGenie",
    "slug": "routegenie",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.routegenie.app"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
